# Application
PROJECT_NAME="Telegram Scraping Platform"

# Database
DATABASE_URL="sqlite:///./test.db"

# Security
JWT_SECRET_KEY="super-secret-jwt-key"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="1440"

# Telegram API Configuration
TELEGRAM_API_ID=""
TELEGRAM_API_HASH=""

# SendGrid Configuration (For User Email Notifications)
# 1. Sign up on sendgrid.com
# 2. Verify a Sender Identity (e.g. notifications@yourdomain.com)
# 3. Create an API Key with Full Access
SENDGRID_API_KEY="SG.your_sendgrid_api_key_here"
SENDGRID_FROM_EMAIL="notifications@yourdomain.com"
